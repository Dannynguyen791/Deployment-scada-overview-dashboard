# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# EoH API: required for live SCADA dashboard data.
# EOH_API_TOKEN is used by the Vercel serverless proxy and should be configured
# in Vercel Environment Variables for production.
EOH_API_BASE_URL="https://backend.eoh.io/api"
EOH_API_TOKEN="YOUR_EOH_TOKEN"

# VITE_EOH_API_TOKEN is only for local browser-to-backend development.
VITE_EOH_API_BASE_URL="https://backend.eoh.io/api"
VITE_EOH_API_TOKEN="YOUR_EOH_TOKEN"
VITE_EOH_POLL_INTERVAL_MS="10000"

# Optional local Vite proxy target when VITE_EOH_API_BASE_URL="/api/eoh".
# Set this to "http://localhost:3002" only when running npm run dev:mock.
VITE_EOH_PROXY_TARGET="https://backend.eoh.io/api"

# Optional: lock the dashboard P-SON value to the exact e-ra/Modbus config.
# VITE_EOH_PSON_CONFIG_ID is the most reliable option if you can find it.
VITE_EOH_PSON_CONFIG_ID="165693"
VITE_EOH_PSON_GATEWAY_ID="13368"
VITE_EOH_PSON_NAME="P-SON"
VITE_EOH_PSON_FUNCTION_CODE="4"
VITE_EOH_PSON_DATA_ADDRESS="58"
VITE_EOH_PSON_DATA_LENGTH="2"
VITE_EOH_PSON_TRANSFORMER="Float - Big Endian"
VITE_EOH_PSON_UNIT_KEYS="PAINT_SHOP_01,XUONG SON"
VITE_EOH_PCON_CONFIG_ID="169059"
VITE_EOH_PCON_GATEWAY_ID="13368"
VITE_EOH_PCON_NAME="P-CON"
